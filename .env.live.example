# KIS Unified STS - live trading compose template
# Copy to .env.live and replace placeholders. Never commit the copied file.

COMPOSE_PROJECT_NAME=kis_live
ENVIRONMENT=live

# Host ports. Defaults avoid conflicts with dev/paper when stacks are compared.
DASHBOARD_HOST_PORT=5082
REDIS_HOST_PORT=6382
PROMETHEUS_HOST_PORT=9092
STREAM_EXPORTER_HOST_PORT=9095
MLFLOW_HOST_PORT=5002
CLICKHOUSE_NATIVE_HOST_PORT=9002
CLICKHOUSE_HTTP_HOST_PORT=8125

# Redis runtime state. DB 1 is required; separate paper/live by compose project.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
REDIS_STOCK_DB=1
REDIS_FUTURES_DB=1
REDIS_SYSTEM_DB=1
REDIS_PASSWORD=CHANGE_ME_LIVE_REDIS_PASSWORD
REDIS_TLS_ENABLED=false
REDIS_TLS_CERT_REQS=required
REDIS_TLS_CA_CERTS=

# Runtime durable storage: SQLite primary, ClickHouse mirror disabled by default.
RUNTIME_STORAGE_BACKEND=sqlite
RUNTIME_STORAGE_SQLITE_PATH=data/runtime/live/runtime.db
RUNTIME_STORAGE_SQLITE_WAL=true
RUNTIME_STORAGE_SQLITE_BUSY_TIMEOUT_MS=5000
RUNTIME_STORAGE_SQLITE_SYNCHRONOUS=NORMAL
RUNTIME_STORAGE_CLICKHOUSE_MIRROR_ENABLED=false
RUNTIME_STORAGE_CLICKHOUSE_DATABASE=market

# Historical market data: file-based by default.
MARKET_DATA_SOURCE=parquet
MARKET_DATA_PARQUET_ROOT=data/market
MARKET_DATA_CLICKHOUSE_ENABLED=false
MARKET_DATA_CLICKHOUSE_STOCK_DATABASE=market
MARKET_DATA_CLICKHOUSE_FUTURES_DATABASE=kospi
DASHBOARD_TRADE_STATS_SOURCE=runtime_ledger

# Optional research profile / analytics mirror settings.
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_STOCK_DATABASE=market
CLICKHOUSE_FUTURES_DATABASE=kospi
CLICKHOUSE_SECURE=false
CLICKHOUSE_VERIFY_SSL=true
CLICKHOUSE_CA_CERT=

# Auth and dashboard. Use strong generated values.
API_KEY=CHANGE_ME_LIVE_API_KEY
API_KEY_HEADER=X-API-Key
METRICS_REQUIRE_AUTH=true
DASHBOARD_REQUIRE_AUTH=true
DASHBOARD_API_KEY=CHANGE_ME_LIVE_DASHBOARD_API_KEY
DASHBOARD_DEV_MODE=false
TRADING_ASSET_CLASS=stock

# KIS live trading credentials and alerts.
KIS_APP_KEY=CHANGE_ME_LIVE_KIS_APP_KEY
KIS_APP_SECRET=CHANGE_ME_LIVE_KIS_APP_SECRET
KIS_IS_REAL=true
KIS_REAL_TRADING=true
TELEGRAM_BOT_TOKEN=CHANGE_ME_LIVE_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=CHANGE_ME_LIVE_TELEGRAM_CHAT_ID
OPENAI_API_KEY=
