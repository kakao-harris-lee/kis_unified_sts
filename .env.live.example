# KIS Unified STS - live trading compose template
# Copy to .env.live and replace placeholders. Never commit the copied file.

COMPOSE_PROJECT_NAME=kis_live
ENVIRONMENT=live

# Host ports. Defaults avoid conflicts with dev/paper when stacks are compared.
DASHBOARD_HOST_PORT=5082
REDIS_HOST_PORT=6382
PROMETHEUS_HOST_PORT=9092
STREAM_EXPORTER_HOST_PORT=9095
MLFLOW_HOST_PORT=5002

# Redis runtime state. DB 1 is required; separate paper/live by compose project.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
REDIS_STOCK_DB=1
REDIS_FUTURES_DB=1
REDIS_SYSTEM_DB=1
REDIS_PASSWORD=CHANGE_ME_LIVE_REDIS_PASSWORD
REDIS_TLS_ENABLED=false
REDIS_TLS_CERT_REQS=required
REDIS_TLS_CA_CERTS=

# Runtime durable storage: SQLite primary.
RUNTIME_STORAGE_BACKEND=sqlite
RUNTIME_STORAGE_SQLITE_PATH=data/runtime/live/runtime.db
RUNTIME_STORAGE_SQLITE_WAL=true
RUNTIME_STORAGE_SQLITE_BUSY_TIMEOUT_MS=5000
RUNTIME_STORAGE_SQLITE_SYNCHRONOUS=NORMAL

# Historical market data: file-based by default.
MARKET_DATA_SOURCE=parquet
MARKET_DATA_PARQUET_ROOT=data/market
DASHBOARD_TRADE_STATS_SOURCE=runtime_ledger

# Auth and dashboard. Use strong generated values.
API_KEY=CHANGE_ME_LIVE_API_KEY
API_KEY_HEADER=X-API-Key
METRICS_REQUIRE_AUTH=true
DASHBOARD_REQUIRE_AUTH=true
DASHBOARD_API_KEY=CHANGE_ME_LIVE_DASHBOARD_API_KEY
NEXT_PUBLIC_API_KEY=CHANGE_ME_LIVE_DASHBOARD_API_KEY
DASHBOARD_DEV_MODE=false
TRADING_ASSET_CLASS=stock
TRADING_MODE=live
TRADING_STRATEGY=
TRADING_INITIAL_CAPITAL=10000000
TRADING_RUN_MODE=daemon
# Required before `--profile trading` can start the live trader.
TRADING_LIVE_CONFIRM=
STOCK_PIPELINE_MODE=shadow
STOCK_POSITIONS_KEY=stock:daemon:positions
STOCK_TICK_STREAM=market:ticks
STOCK_WATCHLIST_KEY=system:daily_watchlist:latest
STOCK_MAX_SYMBOLS=40

# Futures decoupled pipeline (dormant; profiles futures-ingest/futures-pipeline/futures-killswitch).
# Shadow-default. Cutover: set FUTURES_PIPELINE_MODE=live and FUTURES_ORDER_ROUTER_MODE=live
# (see docs/runbooks/futures-pipeline-cutover-f9.md). FUTURES_STRATEGY_SYMBOL = KOSPI200 mini
# front-month code (required for shadow/live; updates quarterly at rollover).
FUTURES_PIPELINE_MODE=shadow
FUTURES_ORDER_ROUTER_MODE=paper
FUTURES_STRATEGY_SYMBOL=
# Current orchestrator path stays enabled until F-9 Gate 2 cutover; set false
# when the decoupled futures pipeline replaces trader-futures.
FUTURES_ORCHESTRATOR_ENABLED=true
# Executor real/paper gate for futures-order-router (PAPER|MOCK|REAL). Keep PAPER
# until the gated live cutover; set REAL to place real KIS orders.
FUTURES_EXECUTOR_TRADING_MODE=PAPER

# KIS live trading credentials and alerts.
KIS_APP_KEY=CHANGE_ME_LIVE_KIS_APP_KEY
KIS_APP_SECRET=CHANGE_ME_LIVE_KIS_APP_SECRET
KIS_STOCK_APP_KEY=CHANGE_ME_LIVE_KIS_APP_KEY
KIS_STOCK_APP_SECRET=CHANGE_ME_LIVE_KIS_APP_SECRET
KIS_FUTURES_APP_KEY=CHANGE_ME_LIVE_KIS_APP_KEY
KIS_FUTURES_APP_SECRET=CHANGE_ME_LIVE_KIS_APP_SECRET
KIS_IS_REAL=true
KIS_REAL_TRADING=true
KIS_MARKET=real
KIS_STOCK_MARKET=real
KIS_FUTURES_MARKET=real
KIS_TOKEN_CACHE_DIR=/app/.cache
TELEGRAM_BOT_TOKEN=CHANGE_ME_LIVE_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=CHANGE_ME_LIVE_TELEGRAM_CHAT_ID
TELEGRAM_STOCK_BOT_TOKEN=CHANGE_ME_LIVE_TELEGRAM_BOT_TOKEN
TELEGRAM_STOCK_CHAT_ID=CHANGE_ME_LIVE_TELEGRAM_CHAT_ID
TELEGRAM_FUTURES_BOT_TOKEN=CHANGE_ME_LIVE_TELEGRAM_BOT_TOKEN
TELEGRAM_FUTURES_CHAT_ID=CHANGE_ME_LIVE_TELEGRAM_CHAT_ID
OPENAI_API_KEY=

# News / LLM stream pipeline (`--profile news`).
DART_API_KEY=
MARKETAUX_API_TOKEN=
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
NEWS_SCORER_CONSUMER_GROUP=news_scorer-v1
