# KIS Unified STS - local development compose defaults
# Safe to commit: replace only if your local dev stack needs different ports.

COMPOSE_PROJECT_NAME=kis_dev
ENVIRONMENT=dev

# Host ports. Keep these unique if paper/live stacks run at the same time.
DASHBOARD_HOST_PORT=5080
REDIS_HOST_PORT=6380
PROMETHEUS_HOST_PORT=9090
STREAM_EXPORTER_HOST_PORT=9093
MLFLOW_HOST_PORT=5000

# Redis runtime state. DB 1 is required; separate environments by compose project.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
REDIS_STOCK_DB=1
REDIS_FUTURES_DB=1
REDIS_SYSTEM_DB=1
REDIS_PASSWORD=changeme
REDIS_TLS_ENABLED=false
REDIS_TLS_CERT_REQS=required
REDIS_TLS_CA_CERTS=

# Runtime durable storage: SQLite primary.
RUNTIME_STORAGE_BACKEND=sqlite
RUNTIME_STORAGE_SQLITE_PATH=data/runtime/dev/runtime.db
RUNTIME_STORAGE_SQLITE_WAL=true
RUNTIME_STORAGE_SQLITE_BUSY_TIMEOUT_MS=5000
RUNTIME_STORAGE_SQLITE_SYNCHRONOUS=NORMAL

# Historical market data: file-based by default.
MARKET_DATA_SOURCE=parquet
MARKET_DATA_PARQUET_ROOT=data/market
DASHBOARD_TRADE_STATS_SOURCE=runtime_ledger

# Auth and dashboard defaults for local dev only.
API_KEY=dev-api-key
API_KEY_HEADER=X-API-Key
METRICS_REQUIRE_AUTH=false
DASHBOARD_REQUIRE_AUTH=false
DASHBOARD_API_KEY=dev-dashboard-key
DASHBOARD_DEV_MODE=true
TRADING_ASSET_CLASS=stock

# KIS / notification placeholders.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_IS_REAL=false
KIS_REAL_TRADING=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
OPENAI_API_KEY=
