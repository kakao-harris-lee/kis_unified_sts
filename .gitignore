.history/
.sisyphus/
.superpowers/
__pycache__/
*/__pycache__/
# Playwright/Chrome MCP browser-session artifacts (console logs, page snapshots)
.playwright-mcp/

# Environment variables (secrets)
.env
.env.local
.env.*.local
# Stack secret env files (filled from .env.*.example, never committed).
# The *.example templates stay tracked; only the secret-filled copies are ignored.
.env.paper
.env.live
.env.production

# IDE
.idea/
.vscode/
*.swp
*.swo

# Python
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
*.egg-info/
dist/
build/
.coverage
coverage.xml

# MLflow
mlruns/

# Logs
*.log
logs/

# KIS token cache (.kis_token_real / .kis_token_mock hold live KIS tokens —
# secrets, never commit). The dir itself is tracked via .gitkeep so the
# ./.cache:/app/.cache bind-mount source exists owned by the deploy user on a
# fresh checkout; otherwise `docker compose up` auto-creates it as root and the
# container (appuser, uid 1000) cannot persist tokens → re-issues on every restart.
/.cache/*
!/.cache/.gitkeep

# Local artifacts
.venv/
output/
pids/
*.pth
monitoring/prometheus/alert_rules.yml
scripts/cron/
scripts/test_model.py

# Generated reports
reports/**
!reports/drills/
!reports/drills/.gitkeep

# KIS API documentation (binary files)
kis_docs/
.kis_token_real
.kis_token_mock
.serena/

# RL/ML training artifacts
models/futures/rl/
models/futures/tft/

# Data
data/
!shared/ml/data/
!shared/ml/data/**
!tests/unit/ml/data/
!tests/unit/ml/data/**
shared/ml/data/**/__pycache__/
shared/ml/data/**/*.pyc
tests/unit/ml/data/**/__pycache__/
tests/unit/ml/data/**/*.pyc
results/
mlflow.db

# Node.js
node_modules/
.next/

# Screenshots / images (root level)
*.png

# Auto Claude data directory
.auto-claude/

