# .env.production.example
# KIS Unified Trading Platform - Production Environment
# 주의: 이 파일에 실제 값을 입력하지 마세요!
# WARNING: NEVER commit actual values!

# =============================================================================
# KIS API (Required)
# =============================================================================
KIS_APP_KEY=REQUIRED
KIS_APP_SECRET=REQUIRED
KIS_ACCOUNT_NO=REQUIRED
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_IS_REAL=true
KIS_REAL_TRADING=true

# =============================================================================
# API Authentication (Required)
# =============================================================================
API_KEY=REQUIRED_STRONG_KEY

# =============================================================================
# Telegram Alerts (Required for production)
# =============================================================================
TELEGRAM_BOT_TOKEN=REQUIRED
TELEGRAM_CHAT_ID=REQUIRED

# =============================================================================
# Infrastructure
# =============================================================================
COMPOSE_PROJECT_NAME=kis_live

# Host ports. Change if another compose project is already bound locally.
DASHBOARD_HOST_PORT=5082
REDIS_HOST_PORT=6382
PROMETHEUS_HOST_PORT=9092
STREAM_EXPORTER_HOST_PORT=9095
MLFLOW_HOST_PORT=5002
CLICKHOUSE_NATIVE_HOST_PORT=9002
CLICKHOUSE_HTTP_HOST_PORT=8125

# Redis Authentication (Required - minimum 16 characters)
REDIS_PASSWORD=REQUIRED_STRONG_PASSWORD

# NOTE: component env vars (REDIS_HOST/PORT/PASSWORD/DB) 사용을 권장합니다.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
REDIS_STOCK_DB=1
REDIS_FUTURES_DB=1
REDIS_SYSTEM_DB=1

# Redis TLS/SSL Configuration. Set true only for a TLS-capable external Redis.
REDIS_TLS_ENABLED=false
REDIS_TLS_CERT_REQS=required
REDIS_TLS_CA_CERTS=/path/to/ca-certificates.crt

# Runtime Storage
RUNTIME_STORAGE_BACKEND=sqlite
RUNTIME_STORAGE_SQLITE_PATH=data/runtime/live/runtime.db
RUNTIME_STORAGE_SQLITE_WAL=true
RUNTIME_STORAGE_SQLITE_BUSY_TIMEOUT_MS=5000
RUNTIME_STORAGE_SQLITE_SYNCHRONOUS=NORMAL
RUNTIME_STORAGE_CLICKHOUSE_MIRROR_ENABLED=false
RUNTIME_STORAGE_CLICKHOUSE_DATABASE=market

# Historical Market Data
MARKET_DATA_SOURCE=parquet
MARKET_DATA_PARQUET_ROOT=data/market
MARKET_DATA_CLICKHOUSE_ENABLED=false
MARKET_DATA_CLICKHOUSE_STOCK_DATABASE=market
MARKET_DATA_CLICKHOUSE_FUTURES_DATABASE=kospi
DASHBOARD_TRADE_STATS_SOURCE=runtime_ledger

# Optional ClickHouse research / analytics mirror
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_STOCK_DATABASE=market
CLICKHOUSE_FUTURES_DATABASE=kospi
CLICKHOUSE_URL=clickhouse://clickhouse:9000/trading

# ClickHouse TLS/SSL Configuration. Set true only for a TLS-capable external ClickHouse.
CLICKHOUSE_SECURE=false
CLICKHOUSE_VERIFY_SSL=true
CLICKHOUSE_CA_CERT=/path/to/ca-certificates.crt

MLFLOW_TRACKING_URI=http://mlflow:5000

# =============================================================================
# Naver Search API (Required when config/news_sources.yaml naver_search is enabled)
# =============================================================================
NAVER_SEARCH_CLIENT_ID=REQUIRED
NAVER_SEARCH_CLIENT_SECRET=REQUIRED

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
PROMETHEUS_PORT=8080
