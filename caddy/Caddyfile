# KIS Unified STS — Single external entry on host port 5080.
#
# Routing (post-Vite-migration, 2026-05-28):
#   /api/*                  → dashboard:8001 (FastAPI — sole owner of backend API)
#                             except /api/kis-builder/* which the Next.js app
#                             proxies server-side (see strategy-builder-ui/next.config.ts).
#   /health, /docs,
#   /openapi.json, /redoc,
#   /metrics                → dashboard:8001 (FastAPI introspection endpoints)
#   everything else         → strategy-builder-ui:3100 (Next.js — sole owner of UI)
#
# HTTP-only on :5080. The host can only expose this port (operator constraint).
# crypto.randomUUID() polyfill stayed in the Vite SPA before its removal; the
# Next.js Strategy Builder code (#346) was always polyfill-free because it
# doesn't call randomUUID at module init.

:5080 {
	log {
		output stdout
		format console
		level INFO
	}

	# All FastAPI traffic carve-out. The dashboard FastAPI owns every /api/*
	# namespace *except* /api/kis-builder/* (which the Next.js app proxies
	# itself), plus its own introspection endpoints.
	@to_dashboard {
		path /api/* /health /docs /openapi.json /redoc /metrics
		not path /api/kis-builder/*
	}
	handle @to_dashboard {
		reverse_proxy dashboard:8001
	}

	# Next.js owns everything else: the dashboard UI (Cockpit, Positions,
	# Signals, Trades, Strategy Lab — ported from the now-removed Vite SPA),
	# the Strategy Builder, and the Strategy Execute UI.
	handle {
		reverse_proxy strategy-builder-ui:3100
	}
}
