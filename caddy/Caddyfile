# KIS Unified STS — Single external entry on host port 5080.
#
# Routing (2026-05-29):
#   /api/kis-builder/*  → dashboard:8001 (Phase 2 register-paper + KIS compat)
#   /api/strategies*,
#   /api/signals*,
#   /api/trades*,
#   /api/health*,
#   /api/strategy-lab*,
#   /api/strategy-builder*,
#   /api/metrics*,
#   /api/trading*,
#   /health, /docs,
#   /openapi.json,
#   /redoc, /metrics    → dashboard:8001 (STS native endpoints)
#   everything else     → strategy-builder-ui:3100 (Next.js)
#                          ← the Next.js catch-all proxy at
#                            /api/[...path]/route.ts handles legacy
#                            upstream-Builder calls (/api/auth, /api/account,
#                            /api/orders, /api/market, /api/symbols, /api/files)
#                            by rewriting them to /api/kis-builder/<path> on
#                            dashboard. Keeps the upstream UI working without
#                            us editing every call site.
#
# HTTP-only on :5080 (operator constraint).

:5080 {
	log {
		output stdout
		format console
		level INFO
	}

	# 1) KIS builder direct namespace — Phase 2 register-paper and the
	#    upstream-compat endpoints both live here. Always dashboard.
	handle /api/kis-builder/* {
		reverse_proxy dashboard:8001
	}

	# 2) STS native dashboard endpoints. Listed individually rather than
	#    via /api/* + exceptions so the compat-proxy fallback under handle{}
	#    can pick up /api/auth, /api/account, etc. without leaking them to
	#    dashboard (which would 404).
	@to_dashboard {
		path /api/strategies /api/strategies/*
		path /api/signals /api/signals/*
		path /api/trades /api/trades/*
		path /api/health /api/health/*
		path /api/strategy-lab /api/strategy-lab/*
		path /api/strategy-builder /api/strategy-builder/*
		path /api/metrics /api/metrics/*
		path /api/trading /api/trading/*
		path /health /docs /openapi.json /redoc /metrics
	}
	handle @to_dashboard {
		reverse_proxy dashboard:8001
	}

	# 3) Everything else → Next.js. UI pages, /_next/* assets, and the
	#    legacy /api/{auth,account,orders,market,symbols,files} compat
	#    namespace handled by strategy-builder-ui's catch-all proxy.
	handle {
		reverse_proxy strategy-builder-ui:3100
	}
}
