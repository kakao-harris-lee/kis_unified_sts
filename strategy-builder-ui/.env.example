# Strategy Builder UI는 기본적으로 same-origin /api/*를 호출하고,
# Next.js server route가 KIS_BUILDER_API_BASE의 /api/kis-builder/*로 proxy합니다.
# NEXT_PUBLIC_API_URL을 설정하면 이 proxy를 우회하므로 일반적으로 비워둡니다.
# NEXT_PUBLIC_API_URL=

# Dashboard compatibility API base.
KIS_BUILDER_API_BASE=http://localhost:5081

# Dashboard auth가 켜진 경우 서버사이드 proxy가 보낼 API key입니다.
# KIS_BUILDER_API_KEY=

# Cockpit/positions/signals/trades pages call the dashboard API from the browser.
# This value is bundled into client assets; set it only for trusted deployments.
# NEXT_PUBLIC_API_KEY=
