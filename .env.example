# =============================================================================
# KIS Unified Trading System - Environment Configuration
# =============================================================================
#
# 이 파일을 .env로 복사하여 실제 값을 입력하세요.
# cp .env.example .env
#
# 구조:
#   1. 공통 인프라 (Compose, Redis, SQLite, Parquet)
#   2. 주식 트레이딩 (quant_moment_sts)
#   3. 선물 트레이딩 (kospi_mini_sts)
#   4. LLM 분석 & 브리핑
#   5. 모니터링 & 대시보드
#
# =============================================================================


# =============================================================================
# [1] 공통 인프라 - SHARED INFRASTRUCTURE
# =============================================================================
# Compose project/volume으로 dev/paper/live를 분리한다. Redis DB 번호로
# 환경을 나누지 않는다.

# -----------------------------------------------------------------------------
# Compose project and host ports
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=kis_dev
DASHBOARD_HOST_PORT=5081
REDIS_HOST_PORT=6379
PROMETHEUS_HOST_PORT=9090
STREAM_EXPORTER_HOST_PORT=9093
MLFLOW_HOST_PORT=5000

# -----------------------------------------------------------------------------
# Redis (캐시, 실시간 상태, Streams)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
# 주의: 프로덕션 환경에서는 반드시 강력한 비밀번호를 설정하세요!
# WARNING: Set a strong password in production! Never commit actual passwords!
REDIS_PASSWORD=changeme

# Redis DB 1 is the only runtime DB. Separate dev/paper/live with
# COMPOSE_PROJECT_NAME and separate Redis volumes, not DB numbers.
REDIS_STOCK_DB=1

# 선물용 Redis DB
REDIS_FUTURES_DB=1

# 시스템 공용 Redis DB (세션, 캐시 등)
REDIS_SYSTEM_DB=1

# 통합 URL (기본)
REDIS_URL=redis://:changeme@redis:6379/1

# Redis TLS/SSL 설정
# TLS 활성화 (true: rediss://, false: redis://)
REDIS_TLS_ENABLED=false

# TLS 인증서 검증 요구사항 (none|optional|required)
REDIS_TLS_CERT_REQS=required

# CA 인증서 경로 (비워두면 시스템 기본 CA 사용)
REDIS_TLS_CA_CERTS=

# -----------------------------------------------------------------------------
# MLflow (실험 추적)
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000

# -----------------------------------------------------------------------------
# Runtime Storage (Redis Streams/state + SQLite durable ledger by default)
# -----------------------------------------------------------------------------
ENVIRONMENT=dev
RUNTIME_STORAGE_BACKEND=sqlite
RUNTIME_STORAGE_SQLITE_PATH=data/runtime/${ENVIRONMENT}/runtime.db
RUNTIME_STORAGE_SQLITE_WAL=true
RUNTIME_STORAGE_SQLITE_BUSY_TIMEOUT_MS=5000
RUNTIME_STORAGE_SQLITE_SYNCHRONOUS=NORMAL
MARKET_DATA_SOURCE=parquet
MARKET_DATA_PARQUET_ROOT=data/market
DASHBOARD_TRADE_STATS_SOURCE=runtime_ledger


# =============================================================================
# [2] 주식 트레이딩 - STOCK TRADING (quant_moment_sts)
# =============================================================================
# 모멘텀/3-Stage Exit 기반 주식 트레이딩

# -----------------------------------------------------------------------------
# KIS API - 주식 계좌
# -----------------------------------------------------------------------------
# 한국투자증권 개발자센터: https://apiportal.koreainvestment.com/
KIS_STOCK_APP_KEY=your_stock_app_key
KIS_STOCK_APP_SECRET=your_stock_app_secret
KIS_STOCK_ACCOUNT_NO=12345678-01

# 실전/모의 투자 (real: 실전, mock: 모의)
KIS_STOCK_MARKET=mock

# -----------------------------------------------------------------------------
# Telegram 알림 - 주식용
# -----------------------------------------------------------------------------
# 주식 트레이딩 전용 봇 (분리 운영 권장)
TELEGRAM_STOCK_BOT_TOKEN=your_stock_bot_token
TELEGRAM_STOCK_CHAT_ID=your_stock_chat_id

# -----------------------------------------------------------------------------
# 주식 전략 설정
# -----------------------------------------------------------------------------
# bb_reversion, volume_momentum, stochrsi_reversal 등
STOCK_STRATEGY=bb_reversion

# 운영 모드 (PAPER: 모의, REAL: 실전)
STOCK_TRADING_MODE=PAPER

# 대시보드 인증
STOCK_DASHBOARD_USERNAME=admin
STOCK_DASHBOARD_PASSWORD=your_secure_password


# =============================================================================
# [3] 선물 트레이딩 - FUTURES TRADING (kospi_mini_sts)
# =============================================================================
# OFI 마이크로스트럭처 기반 KOSPI200 선물 트레이딩

# -----------------------------------------------------------------------------
# KIS API - 선물 계좌
# -----------------------------------------------------------------------------
# 선물 전용 계좌 (주식 계좌와 별도)
KIS_FUTURES_APP_KEY=your_futures_app_key
KIS_FUTURES_APP_SECRET=your_futures_app_secret
KIS_FUTURES_ACCOUNT_NO=87654321-01

# 실전/모의 투자
KIS_FUTURES_MARKET=mock

# -----------------------------------------------------------------------------
# Telegram 알림 - 선물용
# -----------------------------------------------------------------------------
# 선물 트레이딩 전용 봇 (분리 운영 권장)
TELEGRAM_FUTURES_BOT_TOKEN=your_futures_bot_token
TELEGRAM_FUTURES_CHAT_ID=your_futures_chat_id

# -----------------------------------------------------------------------------
# 선물 전략 설정
# -----------------------------------------------------------------------------
# pure_micro (추천), adaptive_micro, ofi_momentum
FUTURES_STRATEGY=pure_micro

# 선물 코드 (빈 값이면 근월물 자동 계산)
# 형식: 101{월코드}{년도} (예: 101F26 = 2026년 1월물)
FUTURES_CODE=

# Dry Run 모드 (true: 주문 없음, false: 실제 주문)
FUTURES_DRY_RUN=true


# =============================================================================
# [4] LLM 분석 & 브리핑 - LLM ANALYSIS
# =============================================================================
# GPT 기반 종목 분석, 시장 브리핑

# -----------------------------------------------------------------------------
# OpenAI API
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key

# 모델 설정
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.3

# LLM 분석 활성화
LLM_ANALYSIS_ENABLED=true

# 리포트 출력 디렉토리
LLM_OUTPUT_DIR=./trading_reports

# -----------------------------------------------------------------------------
# KRX Open API (한국거래소)
# -----------------------------------------------------------------------------
# API 키 발급: https://data.krx.co.kr/
KRX_API_KEY=your_krx_api_key

# -----------------------------------------------------------------------------
# DART API (금융감독원 전자공시)
# -----------------------------------------------------------------------------
# API 키 발급: https://opendart.fss.or.kr/
DART_API_KEY=your_dart_api_key

# -----------------------------------------------------------------------------
# Marketaux API (금융/시장 뉴스)
# -----------------------------------------------------------------------------
# API 토큰 발급: https://www.marketaux.com/
MARKETAUX_API_TOKEN=your_marketaux_api_token

# -----------------------------------------------------------------------------
# Naver Search API (장전/테마 뉴스 검색)
# -----------------------------------------------------------------------------
# 애플리케이션 등록: https://developers.naver.com/apps/#/register
NAVER_SEARCH_CLIENT_ID=your_naver_search_client_id
NAVER_SEARCH_CLIENT_SECRET=your_naver_search_client_secret

# -----------------------------------------------------------------------------
# LLM 브리핑 Telegram (별도 채널 가능)
# -----------------------------------------------------------------------------
# 브리핑 전용 채널 (주식/선물 통합 브리핑)
TELEGRAM_BRIEFING_BOT_TOKEN=your_briefing_bot_token
TELEGRAM_BRIEFING_CHAT_ID=your_briefing_chat_id

# 브리핑 스케줄 (crontab에서 직접 설정, 참고용)
# 08:30 - 장전 브리핑 (llm_premarket_briefing.py)
# 15:30 - 장 마감 브리핑 (llm_market_close_briefing.py)
# 21:00 - 야간 분석 (llm_nightly_analysis.py)


# =============================================================================
# [5] 모니터링 & 대시보드 - MONITORING
# =============================================================================

# -----------------------------------------------------------------------------
# API 인증 (REST API)
# -----------------------------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your_secure_api_key_here

# -----------------------------------------------------------------------------
# 대시보드 인증 (Dashboard Authentication)
# -----------------------------------------------------------------------------
# 대시보드 WebSocket 및 데이터 엔드포인트 인증 설정
# true: API 키 인증 필수, false: 인증 없이 접근 허용 (개발용)
DASHBOARD_REQUIRE_AUTH=true

# 대시보드 전용 API 키 (DASHBOARD_REQUIRE_AUTH=true일 때 필수)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# WebSocket 연결 시: ws://host:port/ws/market?api_key=<이 값>
# REST API 호출 시: X-API-Key 헤더에 포함
DASHBOARD_API_KEY=your_dashboard_api_key_here
# Next.js dashboard pages bundle this value into browser-side dashboard API calls.
# Keep the UI behind trusted access controls when it matches DASHBOARD_API_KEY.
NEXT_PUBLIC_API_KEY=your_dashboard_api_key_here

# -----------------------------------------------------------------------------
# 환경 설정
# -----------------------------------------------------------------------------
# ENVIRONMENT is defined in [1] Runtime Storage. Use dev|paper|live|production.
DEBUG=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Metrics 인증 (Metrics Authentication)
# -----------------------------------------------------------------------------
# true: /metrics 엔드포인트에 API_KEY 인증 필요 (X-API-Key 헤더)
# false: Prometheus 스크래퍼 호환성 위해 인증 없이 접근 허용 (기본값)
METRICS_REQUIRE_AUTH=false

# -----------------------------------------------------------------------------
# Prometheus Metrics
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=8080

# -----------------------------------------------------------------------------
# Data-freshness (대시보드 WebSocket 틱 신선도)
# -----------------------------------------------------------------------------
# market-ingest 데몬이 종목별 마지막 틱 시각을 기록해 주기적으로
# `trading:{stock|futures}:data_freshness` 키에 스냅샷을 기록한다. 대시보드
# health `/api/health/data-freshness`가 이 키를 읽어 신선도 패널을 그린다.
# 노브가 두 접두사로 나뉘는 점에 주의(리네이밍 없이 문서화만):
#   - INGEST_*  : market-ingest 데몬(쓰기 루프)이 소비
#   - DATA_FRESHNESS_* : DataFreshnessTracker(스냅샷 계산/쓰기)가 소비
#
# 주기적 신선도 쓰기 루프 활성화 (기본값: true). false면 record_tick은
# 계속 호출되나 Redis에 스냅샷을 쓰지 않는다.
INGEST_DATA_FRESHNESS_ENABLED=true
# 스냅샷 쓰기 간격(초). 기본값 5. 첫 쓰기 전에 한 간격 대기한다.
INGEST_DATA_FRESHNESS_INTERVAL_SECONDS=5
# 종목이 "fresh"로 집계되는 최근 윈도(초). 기본값 60.
DATA_FRESHNESS_WINDOW_SECONDS=60
# 신선도 키 TTL(초). 기본값 86400(24h) — 죽은 ingest가 신선한 척 못하게 만료.
DATA_FRESHNESS_TTL_SECONDS=86400

# =============================================================================
# [6] 레거시 호환 - LEGACY COMPATIBILITY
# =============================================================================
# 기존 단일 계좌 설정 (하위 호환용)
# 새 프로젝트에서는 [2], [3]의 분리 설정 사용 권장

# 단일 KIS API (주식 또는 선물 중 하나만 사용시)
KIS_APP_KEY=${KIS_STOCK_APP_KEY}
KIS_APP_SECRET=${KIS_STOCK_APP_SECRET}
KIS_ACCOUNT_NO=${KIS_STOCK_ACCOUNT_NO}
KIS_REAL_TRADING=false
KIS_ACCOUNT_PRODUCT_CODE=01

# 단일 Telegram (알림 통합시)
TELEGRAM_BOT_TOKEN=${TELEGRAM_STOCK_BOT_TOKEN}
TELEGRAM_CHAT_ID=${TELEGRAM_STOCK_CHAT_ID}


# =============================================================================
# 참고: Crontab 설정 예시
# =============================================================================
# # 장전 브리핑 (평일 08:30)
# 30 8 * * 1-5 cd /path/to/kis_unified_sts && /usr/bin/python3 scripts/llm_premarket_briefing.py >> /var/log/llm_briefing.log 2>&1
#
# # 장 마감 브리핑 (평일 15:30)
# 30 15 * * 1-5 cd /path/to/kis_unified_sts && /usr/bin/python3 scripts/llm_market_close_briefing.py >> /var/log/llm_briefing.log 2>&1
#
# # 야간 분석 (평일 21:00)
# 0 21 * * 1-5 cd /path/to/kis_unified_sts && /usr/bin/python3 scripts/llm_nightly_analysis.py >> /var/log/llm_briefing.log 2>&1
