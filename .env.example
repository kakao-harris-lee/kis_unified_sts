# KIS Unified Trading System - Environment Variables
# 이 파일을 .env로 복사하여 실제 값을 입력하세요.
# cp .env.example .env

# =============================================================================
# API 인증
# =============================================================================

# API Key for REST API authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secure-api-key-here

# =============================================================================
# 환경 설정
# =============================================================================

# development | production
ENVIRONMENT=development

# Enable debug mode (true/false)
DEBUG=false

# =============================================================================
# Telegram 알림
# =============================================================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (your chat or group ID)
TELEGRAM_CHAT_ID=

# =============================================================================
# KIS API
# =============================================================================

# 한국투자증권 API 인증
KIS_APP_KEY=
KIS_APP_SECRET=

# 계좌 정보
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01

# 실전/모의 (true: 실전, false: 모의)
KIS_REAL_TRADING=false

# =============================================================================
# Database
# =============================================================================

# ClickHouse
CLICKHOUSE_URL=clickhouse://localhost:9000/default

# Redis
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# MLflow
# =============================================================================

# MLflow Tracking Server
MLFLOW_TRACKING_URI=http://localhost:5000

# =============================================================================
# LLM Analysis
# =============================================================================

# OpenAI API Key
OPENAI_API_KEY=

# LLM Model (gpt-4o-mini, gpt-4o, etc.)
LLM_MODEL=gpt-4o-mini

# LLM Settings
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.3
LLM_ANALYSIS_ENABLED=true
LLM_OUTPUT_DIR=./trading_reports

# =============================================================================
# KRX Open API
# =============================================================================

# KRX Open API Key (data.krx.co.kr 에서 발급)
KRX_API_KEY=

# =============================================================================
# Prometheus (Optional)
# =============================================================================

# Prometheus metrics server port
PROMETHEUS_PORT=8080

# =============================================================================
# Docker / Grafana
# =============================================================================

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Grafana root URL (for external access)
GRAFANA_ROOT_URL=http://localhost:3000

# Allow anonymous access (development only)
GRAFANA_ANONYMOUS=false
